    "gold_dark": { "hex": "#B88932", "usage": "Darker gold for data bars, var(--rdv-gold-dark)" },
    "gold_extra_light": { "hex": "#F5D68A", "usage": "Gradient to" },
    "black_bg": { "hex": "#030303", "usage": "Body background (var(--rdv-bg))" },
    "surface_1": { "hex": "#080808", "usage": "Card surface (var(--rdv-surface))" },
    "surface_2": { "hex": "#0B0B0B", "usage": "Secondary surface (var(--rdv-surface-2))" },
    "surface_3": { "hex": "#111111", "usage": "Tertiary surface (var(--rdv-surface-3))" },
    "white_text": { "hex": "#F5F5F5", "usage": "Primary text (var(--rdv-white))" },
    "text_secondary": { "hex": "#A1A1AA", "usage": "Secondary text (var(--rdv-text-secondary))" },
    "text_muted": { "hex": "#8A8A92", "usage": "Muted text (var(--rdv-text-muted))" },
    "blue_accent": { "hex": "#0057FF", "usage": "Secondary accent (CTA buttons)" },
    "green_accent": { "hex": "#25D366", "usage": "WhatsApp button" },
    "green_accent_hover": { "hex": "#1DA851", "usage": "WhatsApp hover" },
    "blue_accent_hover": { "hex": "#0044CC", "usage": "Blue CTA hover" },
    "red_accent": { "hex": "#F87171", "usage": "Error states" },
    "border_white": { "rgba": "rgba(255,255,255,0.06)", "usage": "Default borders (var(--rdv-border))" },
    "glass_bg": { "rgba": "rgba(255,255,255,0.035)", "usage": "Glass card bg (var(--rdv-glass))" }
