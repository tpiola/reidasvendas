    },
    "utilities": {
      "glass_card": "Reusable glassmorphism card component",
      "btn_gold": "Primary gold gradient button",
      "btn_outline_gold": "Outlined gold button",
      "gold_badge": "Gold category badge",
      "section_label": "Gold section label with line",
      "text_gradient_gold": "Gold gradient text",
      "luxury_divider": "Gold gradient divider with dot",
      "hover_lift": "Lift on hover utility",
      "hover_glow": "Glow on hover utility",
