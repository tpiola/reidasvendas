{
  "name": "altiq",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "test": "turbo run test",
    "e2e": "turbo run e2e",
    "a11y": "turbo run a11y",
    "storybook": "turbo run storybook",
    "format": "prettier -w .",
    "ci": "pnpm check && pnpm lint && pnpm test && pnpm build:web && pnpm -C apps/web e2e",
    "build:web": "turbo run build --filter=web"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.30",
    "axe-core": "^4.10.3",
    "prettier": "^3.5.3",
    "turbo": "^2.9.14"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1",
      "ws": ">=8.20.1",
      "uuid": ">=11.1.1"
    }
  }
}
